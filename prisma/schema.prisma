generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String
  password String
  isAdmin  Boolean @default(false)
  tasks    Task[]
}

model Task {
  id          String   @id @default(uuid())
  title       String
  description String
  deadline    DateTime
  userId      String
  fileUrl     String?
  priority    String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}
